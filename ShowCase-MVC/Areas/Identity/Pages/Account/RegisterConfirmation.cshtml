@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register confirmation";
}

<h1>@ViewData["Title"]</h1>

<p>
    We sent a confirmation email to <strong>@Model.Email</strong>. If it does not arrive, use this direct link:
    <a id="confirm-link" href="@Model.EmailConfirmationUrl">confirm your account</a>
</p>
