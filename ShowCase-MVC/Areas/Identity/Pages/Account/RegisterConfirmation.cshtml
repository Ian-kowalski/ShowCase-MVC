@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Registratie bevestigen";
}

<h1>@ViewData["Title"]</h1>

<p>Een bevestigingsmail is verstuurd naar <strong>@Model.Email</strong>.</p>

@if (Model.DisplayConfirmAccountLink)
{
    <div class="alert alert-info mt-3" role="alert">
        <strong>Geen e-mail ontvangen?</strong>
        Klik op de knop hieronder om je account direct te bevestigen:
        <div class="mt-2">
            <a class="btn btn-primary" id="confirm-link" href="@Model.EmailConfirmationUrl">
                Bevestig mijn account
            </a>
        </div>
    </div>
}
