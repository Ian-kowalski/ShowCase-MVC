@{
    ViewData["Title"] = "Lobby";
}

<style>
    .game-lobby {
        display: flex;
        flex-direction: column;
        width: 100%;
        max-width: 360px;
        padding: 13px 24px 27px;
        background-color: #fff;
        margin: 0 auto;
    }

    .game-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px 80px;
        border-radius: 600px;
        background-color: #d9d9d9;
    }

    .game-title {
        font-size: 24px;
        font-family: Inter, sans-serif;
    }

    .player-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-top: 18px;
        padding: 16px 40px;
        border-radius: 16px;
        background-color: #d9d9d9;
        font-size: 20px;
        font-family: Inter, sans-serif;
        gap: 12px;
    }

    .player-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .player-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #aaa;
    }

    .player-dot.connected {
        background-color: #4caf50;
    }

    .player-separator {
        font-family: Inter, sans-serif;
        font-size: 18px;
        color: #555;
    }

    .start-button {
        display: flex;
        justify-content: center;
        align-items: center;
        align-self: center;
        width: 100%;
        max-width: 249px;
        margin-top: 17px;
        padding: 12px 60px;
        border-radius: 16px;
        background-color: #757373;
        color: #fff;
        font-size: 20px;
        font-family: Inter, sans-serif;
        border: none;
        cursor: pointer;
    }

    .start-button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .waiting-message {
        align-self: center;
        margin-top: 8px;
        font-size: 12px;
        font-family: Inter, sans-serif;
        color: #666;
    }
</style>

<section class="game-lobby">
    <header class="game-header">
        <h1 class="game-title">Game Lobby</h1>
    </header>

    <section class="player-section">
        <div class="player-row">
            <div class="player-dot connected" id="dot1"></div>
            <span id="player1Name">@User.Identity?.Name</span>
        </div>
        <span class="player-separator">VS</span>
        <div class="player-row">
            <div class="player-dot" id="dot2"></div>
            <span id="player2Name">Waiting...</span>
        </div>
    </section>

    <button class="start-button" id="goToGameBtn" disabled>Enter Game</button>
    <p class="waiting-message" id="waitingMsg">Waiting for opponent to join...</p>
</section>

@section Scripts {
    <script src="~/js/signalr/dist/browser/signalr.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/gameHub")
            .build();

        const player1Name = document.getElementById('player1Name');
        const player2Name = document.getElementById('player2Name');
        const dot2 = document.getElementById('dot2');
        const goToGameBtn = document.getElementById('goToGameBtn');
        const waitingMsg = document.getElementById('waitingMsg');
        const currentUser = '@User.Identity?.Name';

        connection.on('UpdatePlayers', (players) => {
            const list = Array.from(players);
            if (list[0]) player1Name.textContent = list[0];
            if (list[1]) {
                player2Name.textContent = list[1];
                dot2.classList.add('connected');
                goToGameBtn.disabled = false;
                waitingMsg.textContent = 'Both players connected — ready to play!';
            }
        });

        connection.on('PlayerJoined', (userId, count) => {
            if (count >= 2) {
                dot2.classList.add('connected');
                goToGameBtn.disabled = false;
                waitingMsg.textContent = 'Both players connected — ready to play!';
            }
        });

        connection.start()
            .then(() => connection.invoke('RegisterPlayer', currentUser))
            .catch(err => console.error(err));

        goToGameBtn.addEventListener('click', () => {
            window.location.href = '/Zeeslag/Game';
        });
    </script>
}
